{
  "name": "uvera",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/copy-ffmpeg.mjs && node scripts/sync-legal-docs.mjs && node scripts/generate-version.mjs && vite build",
    "preview": "npm run build && wrangler dev",
    "preview:static": "npm run build && cd dist && python3 -m http.server 4173 --bind 0.0.0.0",
    "deploy": "node scripts/check-deploy-branch.mjs && npm run build && wrangler deploy",
    "preview:cloud": "npx wrangler pages dev dist",
    "release": "node scripts/release.mjs",
    "docs:lint": "node scripts/docs/lint.mjs",
    "docs:index": "node scripts/docs/index.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:deploy": "vitepress build docs && wrangler deploy --config docs.wrangler.jsonc"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@cloudflare/stream-react": "^1.9.3",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/react": "^10.51.0",
    "@splinetool/react-spline": "^4.1.0",
    "@supabase/supabase-js": "^2.45.6",
    "dotenv": "^17.4.2",
    "hls.js": "^1.6.16",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "wrangler": "^4.94.0"
  },
  "overrides": {
    "@docsearch/react": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    }
  }
}
